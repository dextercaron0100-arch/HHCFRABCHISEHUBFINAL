# ─── Server ───────────────────────────────────
PORT=3000

# ─── Security ─────────────────────────────────
JWT_SECRET=replace-with-a-long-random-string-in-production

# ─── CORS ─────────────────────────────────────
# Comma-separated list of allowed origins (your website domains)
# Localhost and common LAN dev origins are accepted automatically by the server.
ALLOWED_ORIGINS=https://yourdomain.com

# ─── Anthropic ────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── AI Bot Context ───────────────────────────
# Describe your business so the AI bot can answer questions accurately
BUSINESS_CONTEXT=We are [Your Company Name], providing [your products/services]. Our support hours are Mon-Fri 9AM-6PM. For urgent matters, request a live agent.
