# Server
PORT=3000

# Security
JWT_SECRET=replace-with-a-long-random-string-in-production

# CORS
# Comma-separated list of allowed origins (your website domains)
# Localhost and common LAN dev origins are accepted automatically by the server.
ALLOWED_ORIGINS=https://yourdomain.com

# Business
BUSINESS_NAME=HHC Franchise Hub
BUSINESS_CONTEXT=We help franchise leads with packages, budget, requirements, location planning, and live support.
SUPPORT_EMAIL=
SUPPORT_PHONE=
BUSINESS_HOURS=Mon-Sat 9AM-6PM

# Bot mode
# keyword   = free keyword replies only
# hybrid    = keyword replies first, Anthropic fallback for unmatched questions
# anthropic = Anthropic replies only
BOT_MODE=keyword

# Optional Anthropic
ANTHROPIC_API_KEY=
